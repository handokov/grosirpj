// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String
  password         String
  phone            String    @default("")
  city             String    @default("Jakarta")
  address          String    @default("")
  province         String    @default("")
  postalCode       String    @default("")
  avatar           String    @default("")  // URL foto profil
  gender           String    @default("")  // "pria" | "wanita" | ""
  dateOfBirth      String    @default("")  // format YYYY-MM-DD
  role             String    @default("buyer") // "buyer" | "seller"
  storeName        String?   // seller only
  storeDescription String?   // seller only
  storeAvatar      String?   // seller only - URL foto toko
  bankName         String?   // seller only - nama bank untuk pembayaran
  bankAccount      String?   // seller only - nomor rekening
  bankHolder       String?   // seller only - nama pemilik rekening
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  products         Product[]
  reviews          Review[]
  sentChats        Chat[]        @relation("SentChats")
  receivedChats    Chat[]        @relation("ReceivedChats")
  buyerOrders      Order[]       @relation("BuyerOrders")
  sellerOrders     Order[]       @relation("SellerOrders")
  wishlist         Wishlist[]
  notifications    Notification[]
  addresses        UserAddress[]
  cartItems        CartItem[]
  productViews     ProductView[]
  searchHistory    SearchHistory[]
}

model UserAddress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String   // "Rumah", "Kantor", "Gudang", etc.
  recipient   String   // Nama penerima
  phone       String   // No. telp penerima
  address     String   // Alamat lengkap
  city        String
  province    String   @default("")
  postalCode  String   @default("")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Product {
  id             String        @id @default(cuid())
  name           String
  description    String        @default("")
  price          Int
  originalPrice  Int           @default(0)
  category       String
  images         String        @default("[]") // JSON array of URLs
  minOrder       Int           @default(1)
  stock          Int           @default(0)
  location       String        @default("Jakarta")
  active         Boolean       @default(true)
  sold           Int           @default(0)
  rating         Float         @default(0)
  weight         Int           @default(500)  // gram, untuk hitung ongkir
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  sellerId       String
  seller         User          @relation(fields: [sellerId], references: [id])

  variantGroups  VariantGroup[]
  orderItems     OrderItem[]
  reviews        Review[]
  wishlist       Wishlist[]
  cartItems      CartItem[]
  productViews   ProductView[]

  @@index([category])
  @@index([sellerId])
  @@index([active])
}

model VariantGroup {
  id          String         @id @default(cuid())
  name        String         // e.g. "Ukuran", "Warna"
  order       Int            @default(0)
  productId   String
  product     Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  options     VariantOption[]

  @@index([productId])
}

model VariantOption {
  id             String       @id @default(cuid())
  value          String       // e.g. "L", "Merah"
  variantGroupId String
  variantGroup   VariantGroup @relation(fields: [variantGroupId], references: [id], onDelete: Cascade)

  @@index([variantGroupId])
}

model Order {
  id              String      @id @default(cuid())
  buyerId         String
  buyer           User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  sellerId        String
  seller          User        @relation("SellerOrders", fields: [sellerId], references: [id])
  status          String      @default("pending") // pending, paid, shipped, delivered, cancelled
  totalAmount     Int
  shippingCost    Int         @default(0)
  shippingAddress String      @default("")
  paymentMethod   String      @default("cod") // cod, transfer, ewallet
  paymentProof    String      @default("")    // Catatan/bukti pembayaran dari buyer
  paidAt          DateTime?                    // Waktu pembayaran dikonfirmasi
  notes           String      @default("")    // Catatan dari buyer
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items           OrderItem[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  productName String
  quantity    Int
  price       Int
  variants    String   @default("{}") // JSON: { "Ukuran": "L", "Warna": "Merah" }

  @@index([orderId])
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rating    Int      // 1-5
  comment   String   @default("")
  createdAt DateTime @default(now())

  @@unique([productId, userId]) // one review per user per product
  @@index([productId])
}

model Chat {
  id         String   @id @default(cuid())
  senderId   String
  sender     User     @relation("SentChats", fields: [senderId], references: [id])
  receiverId String
  receiver   User     @relation("ReceivedChats", fields: [receiverId], references: [id])
  message    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([senderId, receiverId])
  @@index([receiverId, read])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("info") // info, order, chat, promo, new_order, payment, shipping
  read      Boolean  @default(false)
  link      String   @default("")
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  variants  String   @default("{}") // JSON: { "Ukuran": "L", "Warna": "Merah" }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId, variants]) // satu entry per kombinasi user+produk+varian
  @@index([userId])
  @@index([productId])
}

model ProductView {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  viewCount Int      @default(1)
  lastViewed DateTime @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, productId]) // satu record per user per produk
  @@index([userId, lastViewed])
  @@index([productId])
}

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query     String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
